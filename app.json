{
	"expo": {
		"name": "Noobify-App",
		"slug": "noobify-app",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "noobifyapp",
		"userInterfaceStyle": "dark",
		"ios": {
			"icon": "./assets/expo.icon"
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#0A0B0F",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"predictiveBackGestureEnabled": false,
			"package": "com.involvex.noobifyapp"
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"backgroundColor": "#0A0B0F",
					"android": {
						"image": "./assets/images/splash-icon.png",
						"imageWidth": 76
					}
				}
			],
			[
				"llama.rn",
				{
					"forceCxx20": true,
					"enableOpenCLAndHexagon": true
				}
			],
			"expo-sqlite",
			"expo-font",
			"expo-image",
			"expo-status-bar",
			"expo-web-browser",
			[
				"@react-native-voice/voice",
				{
					"microphonePermission": "Allow Noobify to access your microphone for speech-to-text.",
					"speechRecognitionPermission": "Allow Noobify to recognize your speech."
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}
