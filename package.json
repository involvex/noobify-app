{
	"name": "noobify-app",
	"version": "1.0.0",
	"private": true,
	"description": "An App to Simplify Tech things.",
	"author": "involvex",
	"main": "expo-router/entry",
	"scripts": {
		"android": "expo run:android",
		"check": "bun run lint:fix && bunx prettier --write . && bunx expo install --check && bunx expo-doctor --verbose && bun run typecheck",
		"format": "prettier . --write",
		"ios": "expo run:ios",
		"lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
		"lint:fix": "eslint . --fix",
		"reset-project": "node ./scripts/reset-project.js",
		"start": "expo start",
		"typecheck": "tsc --noEmit",
		"web": "expo start --web"
	},
	"prettier": "@involvex/prettier-config",
	"dependencies": {
		"@expo/ui": "~57.0.3",
		"@expo/vector-icons": "^15.0.2",
		"expo": "~57.0.2",
		"expo-constants": "~57.0.3",
		"expo-device": "~57.0.0",
		"expo-file-system": "~57.0.0",
		"expo-font": "~57.0.0",
		"expo-glass-effect": "~57.0.0",
		"expo-image": "~57.0.0",
		"expo-linking": "~57.0.1",
		"expo-router": "~57.0.3",
		"expo-speech-recognition": "^56.0.1",
		"expo-splash-screen": "~57.0.2",
		"expo-sqlite": "~57.0.0",
		"expo-status-bar": "~57.0.0",
		"expo-symbols": "~57.0.0",
		"expo-system-ui": "~57.0.0",
		"expo-web-browser": "~57.0.0",
		"llama.rn": "^0.12.5",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-native": "0.86.0",
		"react-native-gesture-handler": "~2.32.0",
		"react-native-paper": "^5.15.3",
		"react-native-reanimated": "4.5.0",
		"react-native-safe-area-context": "~5.7.0",
		"react-native-screens": "4.25.2",
		"react-native-view-shot": "5.1.0",
		"react-native-web": "~0.21.0",
		"react-native-worklets": "0.10.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@involvex/prettier-config": "^0.0.5",
		"@types/react": "~19.2.2",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "5.0.0",
		"globals": "^17.7.0",
		"prettier": "^3.9.4",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.62.1"
	},
	"trustedDependencies": [
		"llama.rn"
	]
}
